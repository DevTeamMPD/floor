# Vision-AI provider: gemini (default) | openai | anthropic | openrouter
OCR_PROVIDER=gemini

# Gemini (primary)
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter (fallback อัตโนมัติเมื่อ Gemini ติด quota)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model ที่ใช้ผ่าน OpenRouter (default: gemini-2.0-flash ฟรี)
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# OpenAI (ถ้าใช้ OCR_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (ถ้าใช้ OCR_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
